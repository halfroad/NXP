org.eclipse.core.variables.valueVariables=<?xml version\="1.0" encoding\="UTF-8" standalone\="no"?>\r\n<valueVariables>\r\n    <valueVariable description\="Location of the Volkano utility script." name\="VOLKANO_UTILITY_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/tools/S32Debugger/Debugger/Server/CCS/bin"/>\r\n    <valueVariable name\="S32DS_INITIALIZATION_SCRIPTS_DIR" readOnly\="false" value\="${S32DS_GDB_SERVER_DIR}/Debugger/scripts"/>\r\n    <valueVariable description\="Location of the S32Flash tool" name\="S32DS_FLASH_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/tools/S32FlashTool"/>\r\n    <valueVariable name\="S32DS_GDB_SERVER_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/tools/S32Debugger"/>\r\n    <valueVariable description\="Location of the Arm32 S32K3 build tools GNU 9.2" name\="S32DS_K3_ARM32_GNU_9_2_TOOLCHAIN_DIR" readOnly\="false" value\="${S32DS_ARM32_GNU_9_2_TOOLCHAIN_DIR}"/>\r\n    <valueVariable description\="Location of the Arm64 build tools" name\="S32DS_ARM64_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_b1620/gcc-6.3-arm64-eabi"/>\r\n    <valueVariable name\="arm32_cross_prefix" readOnly\="false" value\="arm-none-eabi-"/>\r\n    <valueVariable description\="Location of the Arm32 S32K3 build tools GNU 10.2" name\="S32DS_K3_ARM32_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${S32DS_ARM32_GNU_10_2_TOOLCHAIN_DIR}"/>\r\n    <valueVariable description\="Location of the GNU 10.2 Arm64 build tools" name\="S32DS_ARM64_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v10.2/gcc-10.2-arm64-eabi"/>\r\n    <valueVariable name\="arm64_cross_suffix" readOnly\="false"/>\r\n    <valueVariable description\="GDB Client Path for Arm32" name\="S32DS_GDB_ARM32_PY" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm32-eabi/bin/arm-none-eabi-gdb-py"/>\r\n    <valueVariable name\="S32DS_GDB_SERVER_EXECUTABLE_PATH" readOnly\="false" value\="${S32DS_GDB_SERVER_DIR}/Debugger/Server/gta/gta"/>\r\n    <valueVariable description\="Location of the Arm32 EWL2" name\="S32DS_ARM32_EWL_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_b1620/arm32_ewl2"/>\r\n    <valueVariable name\="arm64_linux_cross_prefix" readOnly\="false" value\="aarch64-linux-gnu-"/>\r\n    <valueVariable name\="S32DS_GDB_CLIENT_ISP_EXECUTABLE_PATH" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-7.12-isp/bin/isp-gdb-py"/>\r\n    <valueVariable name\="S32DS_T32_PATH" readOnly\="false" value\="C\:/T32"/>\r\n    <valueVariable name\="arm64_linux_cross_suffix" readOnly\="false"/>\r\n    <valueVariable description\="Path to J-Link installation folder" name\="jlink_path" readOnly\="false" value\="D\:/ProgramFiles/NXP/S32DS.3.5/Drivers/Segger"/>\r\n    <valueVariable name\="arm64_cross_prefix" readOnly\="false" value\="aarch64-none-elf-"/>\r\n    <valueVariable name\="S32DS_T32_TEMP" readOnly\="false" value\="C\:/Windows/Temp"/>\r\n    <valueVariable description\="Location of Trace resources" name\="S32DS_TRACE_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/tools/S32Trace"/>\r\n    <valueVariable description\="Location of the Arm64 Linux GNU_10_2 build tools" name\="S32DS_ARM64_LINUX_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v10.2/gcc-10.2-arm64-linux"/>\r\n    <valueVariable description\="Location of the diab tools" name\="S32DS_DIAB_TOOLCHAIN_DIR" readOnly\="false"/>\r\n    <valueVariable description\="GDB Client Path for Arm64" name\="S32DS_GDB_ARM64_PY" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm64-eabi/bin/aarch64-none-elf-gdb-py"/>\r\n    <valueVariable description\="GDB Client Path for Arm32" name\="S32DS_GDB_ARM32_EXE" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm32-eabi/bin/arm-none-eabi-gdb"/>\r\n    <valueVariable description\="Location of the Arm64 Linux GNU_9_2 build tools" name\="S32DS_ARM64_LINUX_GNU_9_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v9.2/gcc-9.2-arm64-linux"/>\r\n    <valueVariable description\="GDB Client Path for Arm64 Linux" name\="S32DS_GDB_ARM64_LINUX_PY" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm64-linux/bin/aarch64-linux-gnu-gdb-py"/>\r\n    <valueVariable description\="Location of the Arm32 build tools" name\="S32DS_ARM32_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_b1620/gcc-6.3-arm32-eabi"/>\r\n    <valueVariable description\="GDB Client Path for Arm64 Linux" name\="S32DS_GDB_ARM64_LINUX_EXE" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm64-linux/bin/aarch64-linux-gnu-gdb"/>\r\n    <valueVariable description\="Location of GNU utils" name\="MSYS_LOC" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/msys32/usr/bin"/>\r\n    <valueVariable description\="Python location in Windows system" name\="S32DS_PYTHONPATH_WIN32" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/msys32/mingw32/lib/python2.7;${eclipse_home}../S32DS/build_tools/msys32/mingw32/lib/python2.7/site-packages"/>\r\n    <valueVariable description\="Location of the Arm64 GNU_9_2 build tools" name\="S32DS_ARM64_GNU_9_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v9.2/gcc-9.2-arm64-eabi"/>\r\n    <valueVariable name\="S32DS_GDB_CLIENT_APEX_EXECUTABLE_PATH" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-7.12-apex/bin/apex-gdb-py"/>\r\n    <valueVariable description\="GDB Client Path for Arm64" name\="S32DS_GDB_ARM64_EXE" readOnly\="false" value\="${eclipse_home}../S32DS/tools/gdb-arm/arm64-eabi/bin/aarch64-none-elf-gdb"/>\r\n    <valueVariable name\="S32DS_GHS_PATH" readOnly\="false" value\=""/>\r\n    <valueVariable description\="Location of the GNU 10.2 Arm32 build tools" name\="S32DS_ARM32_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v10.2/gcc-10.2-arm32-eabi"/>\r\n    <valueVariable description\="Location of the Arm64 Linux build tools" name\="S32DS_ARM64_LINUX_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_b1620/gcc-6.3-arm64-linux"/>\r\n    <valueVariable description\="Name of the J-Link executable" name\="jlink_gdbserver" readOnly\="false" value\="JLinkGDBServerCL.exe"/>\r\n    <valueVariable name\="arm32_cross_suffix" readOnly\="false"/>\r\n    <valueVariable description\="Location of the Arm32 newlib libraries" name\="S32DS_ARM32_NEWLIB_DIR" readOnly\="false" value\="${S32DS_ARM32_TOOLCHAIN_DIR}/arm-none-eabi/newlib"/>\r\n    <valueVariable description\="Location of the Arm32 GNU_9_2 build tools" name\="S32DS_ARM32_GNU_9_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v9.2/gcc-9.2-arm32-eabi"/>\r\n</valueVariables>\r\n
